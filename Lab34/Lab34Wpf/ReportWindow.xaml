<Window x:Class="Lab34Wpf.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчет по заказам"
        Height="520" Width="920"
        Loaded="ReportWindow_Loaded">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid x:Name="ReportGrid"
                  IsReadOnly="True"
                  AutoGenerateColumns="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Открыть PDF в таблицу"
                    Padding="12,6"
                    Margin="0,0,10,0"
                    Click="OpenPdf_Click" />
            <Button Content="Печать"
                    Padding="12,6"
                    Click="Print_Click" />
        </StackPanel>
    </Grid>
</Window>
