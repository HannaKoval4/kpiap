<Window x:Class="Lab28Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab28Wpf"
        mc:Ignorable="d"
        Title="Lab 28 (WPF)" Height="520" Width="980"
        Background="#0B1220">
    <Window.Resources>
        <Style x:Key="AnimatedHideButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Background" Value="#1F2937" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#273449" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0F172A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#0F172A" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="16" Padding="14">
            <StackPanel>
                <TextBlock Text="Лабораторная 28 (WPF)" FontSize="20" FontWeight="SemiBold" Foreground="#E5E7EB" />
                <TextBlock Text="1) 3 кнопки исчезают с анимацией изменения формы.  2) Анимация положения солнца по текущему времени."
                           Margin="0,6,0,0" Foreground="#94A3B8" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,14,0,0" Background="#0F172A" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="16" Padding="12">
            <TabControl Background="Transparent" BorderThickness="0" Foreground="#E5E7EB">
                <TabItem Header="Задание 1">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Нажмите на кнопки — они исчезнут с анимацией." Foreground="#CBD5E1" />
                            <Button Content="Вернуть все"
                                    Margin="14,0,0,0"
                                    Padding="14,8"
                                    Background="#0B3B59"
                                    BorderBrush="#075985"
                                    Click="ResetButtons_Click" />
                        </StackPanel>

                        <UniformGrid Grid.Row="1" Margin="0,16,0,0" Columns="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button x:Name="Btn1" Style="{StaticResource AnimatedHideButtonStyle}" Content="Кнопка 1" Click="HideButton_Click" Margin="8" MinWidth="160" />
                            <Button x:Name="Btn2" Style="{StaticResource AnimatedHideButtonStyle}" Content="Кнопка 2" Click="HideButton_Click" Margin="8" MinWidth="160" />
                            <Button x:Name="Btn3" Style="{StaticResource AnimatedHideButtonStyle}" Content="Кнопка 3" Click="HideButton_Click" Margin="8" MinWidth="160" />
                        </UniformGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Задание 2">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel LastChildFill="False">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <TextBlock Text="Солнце движется по дуге по текущему времени." Foreground="#CBD5E1" VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <TextBlock Text="Время:" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock x:Name="NowText" Foreground="#E5E7EB" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                        </DockPanel>

                        <Border Grid.Row="1" Margin="0,16,0,0" Background="#020617" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="16" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Canvas x:Name="SkyCanvas" Background="Transparent" Height="320" SizeChanged="SkyCanvas_SizeChanged">
                                    <Rectangle Width="{Binding ElementName=SkyCanvas, Path=ActualWidth}"
                                               Height="{Binding ElementName=SkyCanvas, Path=ActualHeight}"
                                               Fill="#071226" RadiusX="16" RadiusY="16" />

                                    <Line X1="0"
                                          Y1="{Binding ElementName=SkyCanvas, Path=ActualHeight}"
                                          X2="{Binding ElementName=SkyCanvas, Path=ActualWidth}"
                                          Y2="{Binding ElementName=SkyCanvas, Path=ActualHeight}"
                                          Stroke="#0B2A4A"
                                          StrokeThickness="2" />

                                    <Path x:Name="ArcPath" Stroke="#0B2A4A" StrokeThickness="2" Opacity="0.85" />

                                    <Ellipse x:Name="Sun"
                                             Width="44" Height="44"
                                             Fill="#FBBF24"
                                             Stroke="#F59E0B"
                                             StrokeThickness="2" />
                                </Canvas>

                                <TextBlock Grid.Row="1"
                                           Margin="0,10,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="#94A3B8"
                                           Text="Модель: 06:00 слева, 12:00 сверху, 18:00 справа" />
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
